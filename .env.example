# ── Application configuration ──────────────────────────────────────
# Path to the YAML configuration file (default: config.yaml)
# CONFIG_PATH=config.yaml

# API key for authenticating webhook requests (overrides config file)
ACME_WEBHOOK_API_KEY=change-me

# ── Runtime (optional) ─────────────────────────────────────────────
# FastAPI/uvicorn host and port when running directly
# HOST=0.0.0.0
# PORT=8000
